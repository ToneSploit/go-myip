# Environment Configuration
ENVIRONMENT=development
LOG_LEVEL=info
PORT=8080

# Railway will automatically set these in production:
# RAILWAY_ENVIRONMENT=production
# PORT=<assigned-port>

# For GeoIP lookups, you can obtain a free license key from MaxMind:
MAXMIND_LICENSE_ID=key-placeholder
GEOIP_ENABLED=false

# <script src="https://tinylytics.app/embed/-some-key-here-.js" defer></script>
TINYLYTICS=-some-key-here-

APP_RATE_LIMIT_REQUESTS_PER_MINUTE=20
APP_RATE_LIMIT_BURST=10
APP_RATE_LIMIT_EXPIRES_SECONDS=360